{
  "name": "pac-collector",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "clean:dotunderscore": "node scripts/clean_dotunderscore.mjs",
    "test:unit": "pnpm clean:dotunderscore && vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "pnpm clean:dotunderscore && playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:rust": "pnpm clean:dotunderscore && cd src-tauri && cargo test --lib -j 2",
    "verify": "pnpm test:rust && pnpm test:unit && pnpm test:e2e"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/ui": "^4.1.5",
    "jsdom": "^29.1.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.5"
  }
}
